rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Helper for Common Types
    function isPositiveNumber(val) {
      return val is number && val >= 0;
    }

    // User Profile Rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.userId == request.auth.uid &&
               data.name is string && data.name.size() <= 100 &&
               data.age is number && data.age > 0 &&
               data.height is number && data.height > 0 &&
               data.weight is number && data.weight > 0 &&
               data.gender in ['male', 'female', 'other'] &&
               data.activityLevel in ['sedentary', 'light', 'moderate', 'active', 'very_active'] &&
               data.goal in ['lose_weight', 'maintain', 'gain_muscle'] &&
               data.dailyCalorieTarget is number;
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time;
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().userId == existing().userId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time;
    }

    // Food Logs Rules
    match /foodLogs/{logId} {
      function isValidFoodLog(data) {
        return data.userId == request.auth.uid &&
               data.calories is number && data.calories >= 0 &&
               data.protein is number &&
               data.carbs is number &&
               data.fat is number &&
               data.date is string &&
               data.mealType in ['breakfast', 'lunch', 'dinner', 'snack'] &&
               (!('notes' in data) || data.notes is string);
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && 
                    isValidFoodLog(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && existing().userId == request.auth.uid && 
                    isValidFoodLog(incoming()) && 
                    incoming().userId == existing().userId &&
                    incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // Exercise Logs Rules
    match /exerciseLogs/{logId} {
      function isValidExerciseLog(data) {
        return data.userId == request.auth.uid &&
               data.caloriesBurned is number && data.caloriesBurned >= 0 &&
               data.durationMinutes is number && data.durationMinutes >= 0 &&
               data.activityType is string &&
               (!('workoutDetails' in data) || (data.workoutDetails is list && data.workoutDetails.size() <= 30));
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && 
                    isValidExerciseLog(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && existing().userId == request.auth.uid && 
                    isValidExerciseLog(incoming()) && 
                    incoming().userId == existing().userId &&
                    incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
